{
    // 使用 IntelliSense 了解相关属性。 
    // 悬停以查看现有属性的描述。
    // 欲了解更多信息，请访问: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "LLDB C++ Debug",
            "type": "lldb",
            "request": "launch",
            // "program": "${workspaceFolder}/bazel-bin/onboard/nets/bev_road_geometry/bev_road_geometry_libtorch_test",
            "program": "${workspaceFolder}/bazel-bin/onboard/perception/vision/bev_road_geometry/bev_road_geometry_adapter_test",
            "args": [],
            "cwd": "${workspaceFolder}",
            "initCommands": [
                "command script import ${workspaceFolder}/scripts/lldb/qtensor"
            ],
            "sourceMap": {
                "/proc/self/cwd/": "${workspaceFolder}"
            },
        },
        {
            "name": "CUDA C++: Launch",
            "type": "cuda-gdb",
            "request": "launch",
            "program": "${workspaceFolder}/bazel-bin/onboard/nets/qnn/qnn/impl/tensorrt_backend/custom_op/custom_op_test",
            "args": [],
            "cwd": "${workspaceFolder}",
            "sourceMap": {
                "/proc/self/cwd/": "${workspaceFolder}"
            }
        },
        {
            "name": "CUDA C++: Attach",
            "type": "cuda-gdb",
            "request": "attach",
            "pid": "${command:pickProcess}"
        },
        {
            "name": "Qwen2-VL Infer Debug",
            "type": "lldb",
            "request": "launch",
            "stopOnEntry": true,
            "program": "${workspaceFolder}/build-clang-debug/infer/qwen2_vl_infer",
            "args": [
                "--engineDir=${workspaceFolder}/models/Qwen2-VL-2B-Instruct/engines/llm",
                "--multimodalEngineDir=${workspaceFolder}/models/Qwen2-VL-2B-Instruct/engines/visual",
                "--inputFile=${workspaceFolder}/infer/input_qwen2_vl_2b_example.json",
                "--outputFile=${workspaceFolder}/infer/output_qwen2_vl_2b_example.json",
                "--debug"
            ],
            "cwd": "${workspaceFolder}",
            "initCommands": [
                "settings set target.disable-aslr false"
            ],
            "env": {
                "EDGELLM_PLUGIN_PATH": "${workspaceFolder}/build-clang-debug/edgellm/libNvInfer_edgellm_plugin.so"
            },
            "sourceMap": {
                "/proc/self/cwd/": "${workspaceFolder}"
            }
        },
    ]
}