{
    "name": "TensorRT Edge-LLM Dev",
    "build": {
        "dockerfile": "Dockerfile",
        "context": "..",
        "args": {
            "BASE_IMAGE": "swr.cn-north-4.myhuaweicloud.com/ddn-k8s/docker.io/nvcr.io/nvidia/pytorch:25.12-py3",
            "USER_UID": "${localEnv:UID}",
            "USER_GID": "${localEnv:GID}"
        }
    },
    "runArgs": [
        "--gpus",
        "all",
        "--ipc=host",
        "--ulimit",
        "memlock=-1",
        "--ulimit",
        "stack=67108864"
    ],
    "remoteUser": "qcraft",
    "containerUser": "qcraft",
    "updateRemoteUserUID": false,
    "workspaceFolder": "/workspaces/trt_edgellm_docker",
    "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/trt_edgellm_docker,type=bind,consistency=cached",
    "mounts": [
        "source=${localEnv:HOME}/.cache/pip,target=/home/qcraft/.cache/pip,type=bind,consistency=cached",
        "source=${localEnv:HOME}/.cache/uv,target=/home/qcraft/.cache/uv,type=bind,consistency=cached",
        "source=${localEnv:HOME}/.ccache,target=/home/qcraft/.ccache,type=bind,consistency=cached",
        "source=${localEnv:HOME}/.vscode-server,target=/home/qcraft/.vscode-server,type=bind,consistency=cached",
        "source=${localEnv:HOME}/.cursor-server,target=/home/qcraft/.cursor-server,type=bind,consistency=cached"
    ],
    "initializeCommand": "bash .devcontainer/ensure_host_mounts.sh",
    "onCreateCommand": "bash .devcontainer/on_create.sh",
    "postStartCommand": "bash .devcontainer/devcontainer_healthcheck.sh",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cmake-tools",
                "ms-python.python",
                "llvm-vs-code-extensions.vscode-clangd"
            ],
            "settings": {
                "cmake.buildDirectory": "${workspaceFolder}/build",
                "cmake.sourceDirectory": "${workspaceFolder}",
                "cmake.configureOnOpen": true,
                "python.defaultInterpreterPath": "${workspaceFolder}/3rdparty/TensorRT-Edge-LLM/.venv/bin/python",
                "clangd.arguments": []
            }
        }
    }
}